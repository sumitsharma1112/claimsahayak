# ---- Public site (apps/web) -------------------------------------------------
# Canonical origin; used for SEO canonical tags and the analytics allow-list.
NEXT_PUBLIC_SITE_URL=https://claimsahayak.example
# Where published, immutable Rule Packs are served from (V3 §2.6).
# The site falls back to its bundled pack if this is unreachable or tampered.
NEXT_PUBLIC_RULES_CDN_URL=https://claimsahayak.example/rules
# Analytics ingestion endpoint (V3 §4). Leave empty to disable emission.
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# ---- Backend (apps/backend) -------------------------------------------------
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0
DATABASE_URL=postgres://claimsahayak:change-me@localhost:5432/claimsahayak
# Coarse region tagging in analytics (decision D-1). Default OFF per V3 §4.1.
ANALYTICS_REGION_TAGGING=off

# ---- Admin (apps/admin) -----------------------------------------------------
ADMIN_SESSION_SECRET=change-me-64-random-bytes

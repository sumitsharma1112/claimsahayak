{
  "name": "claimsahayak",
  "private": true,
  "version": "0.1.0",
  "description": "ClaimSahayak \u2014 independent guide for preparing Post Office savings death-claim applications. Not an official India Post website.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "test:a11y": "pnpm --filter @claimsahayak/web test:a11y",
    "build": "pnpm -r build",
    "budgets": "node scripts/check-budgets.mjs",
    "dev:web": "pnpm --filter @claimsahayak/web dev",
    "dev:admin": "pnpm --filter @claimsahayak/admin dev",
    "dev:backend": "pnpm --filter @claimsahayak/backend dev",
    "validate-pack": "pnpm --filter @claimsahayak/rule-pack run validate-pack",
    "build-pack": "pnpm --filter @claimsahayak/rule-pack run build-pack",
    "lint-pack": "pnpm --filter @claimsahayak/rule-pack run lint-pack"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.2.0"
  }
}